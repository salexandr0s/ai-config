# AI Config Environment Variables
# Copy to ~/.claude/.env and customize

# Config version (auto-set by install.sh)
AI_CONFIG_VERSION=1.0.0

# House mode (fast/normal/deep) — usually set by launcher
# AI_HOUSE_MODE=normal

# Session start timestamp — set by cl launcher
# AI_SESSION_START_TS=

# Hook toggles (set to 0 to disable)
# AI_HOOK_SESSION_CAPTURE=1
# AI_HOOK_TAB_TITLE=1
# AI_HOOK_VERSION_CHECK=1

# Notification settings
# AI_NOTIFY_ALWAYS=0
# AI_NOTIFY_COOLDOWN_SECONDS=15
# AI_NOTIFY_MIN_SECONDS=15
# AI_NOTIFY_SOUND=/System/Library/Sounds/Glass.aiff
# AI_NOTIFY_NTFY_TOPIC=

# Weather/location (statusline)
# AI_STATUSLINE_WEATHER=1
