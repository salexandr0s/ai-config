{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/GitHub/ai-config/scripts/claude-post-edit-format.sh\" \"$CLAUDE_FILE_PATH\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/GitHub/ai-config/scripts/claude-pre-bash-guard.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/GitHub/terminal-config/bin/ai-notify\" claude stop >/dev/null 2>&1 || true",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
