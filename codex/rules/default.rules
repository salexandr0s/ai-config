prefix_rule(pattern=["readlink"], decision="allow")
prefix_rule(pattern=["ps"], decision="allow")
prefix_rule(pattern=["lsof"], decision="allow")

# Docker (non-destructive)
prefix_rule(pattern=["docker", "build"], decision="allow")
prefix_rule(pattern=["docker", "run"], decision="allow")
prefix_rule(pattern=["docker", "ps"], decision="allow")
prefix_rule(pattern=["docker", "logs"], decision="allow")
prefix_rule(pattern=["docker", "exec"], decision="allow")
prefix_rule(pattern=["docker", "compose"], decision="allow")
prefix_rule(pattern=["docker", "images"], decision="allow")
prefix_rule(pattern=["docker", "pull"], decision="allow")
prefix_rule(pattern=["docker", "inspect"], decision="allow")

# Custom dev scripts
prefix_rule(pattern=["dev-verify"], decision="allow")
prefix_rule(pattern=["dev-format"], decision="allow")
prefix_rule(pattern=["dev-status"], decision="allow")

# Note: destructive commands (rm -rf, sudo, dd, git push --force, etc.)
# are explicitly denied at the top of this file, matching Claude Code's deny list.
